# Yandex Search API credentials
# Get these from https://console.yandex.cloud/
YANDEX_SEARCH_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# Yandex Wordstat (v2) credentials — served by the Yandex Cloud Search API.
# Reuses the Search API key + folder above by default. To use a separate key,
# set YANDEX_WORDSTAT_API_KEY (it takes precedence over YANDEX_SEARCH_API_KEY).
# Likewise YANDEX_WORDSTAT_FOLDER_ID overrides YANDEX_FOLDER_ID if set.
# YANDEX_WORDSTAT_API_KEY=your_separate_api_key_here
# YANDEX_WORDSTAT_FOLDER_ID=your_separate_folder_id_here

# Yandex Webmaster API credentials
# Get these from https://oauth.yandex.com/
YANDEX_WEBMASTER_TOKEN=your_oauth_token_here

# Yandex Metrica API credentials
# Get these from https://oauth.yandex.com/ (scope: metrika:read)
YANDEX_METRIKA_TOKEN=your_oauth_token_here

# Optional: for OAuth flow (run `npx <package> auth` to get token)
YANDEX_CLIENT_ID=your_client_id_here
YANDEX_CLIENT_SECRET=your_client_secret_here
